/*---
esid: sec-createdecoratorcontextobject
desc: Context kind is the string "getter" when decorating a getter
template: getters/standard/**/*
features: [decorators]
---*/

//- decorators
function dec(_, context) {
  assert.sameValue(context.kind, "getter");
}

//- application
@dec
